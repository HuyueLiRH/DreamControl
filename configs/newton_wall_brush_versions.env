# Version pins for rebuilding the Newton wall-brush sim-to-sim environment.
# Source this file from DreamControl root, or let the helper scripts load it.

DREAMCONTROL_REPO="${DREAMCONTROL_REPO:-https://github.com/HuyueLiRH/DreamControl.git}"
DREAMCONTROL_REF="${DREAMCONTROL_REF:-codex/newton-wall-brush-reproduction-pins}"

ISAACLAB_NEWTON_FORK_REPO="${ISAACLAB_NEWTON_FORK_REPO:-https://github.com/HuyueLiRH/IsaacLab.git}"
ISAACLAB_NEWTON_UPSTREAM_REPO="${ISAACLAB_NEWTON_UPSTREAM_REPO:-https://github.com/isaac-sim/IsaacLab.git}"
ISAACLAB_NEWTON_REF="${ISAACLAB_NEWTON_REF:-v3.0.0-beta}"

NEWTON_FORK_REPO="${NEWTON_FORK_REPO:-https://github.com/HuyueLiRH/newton.git}"
NEWTON_UPSTREAM_REPO="${NEWTON_UPSTREAM_REPO:-https://github.com/newton-physics/newton.git}"
NEWTON_REF="${NEWTON_REF:-v1.2.1}"

NEWTON_WALL_BRUSH_WORKSPACE="${NEWTON_WALL_BRUSH_WORKSPACE:-/root/autodl-tmp/newton-wall-brush}"
ISAACLAB_NEWTON_DIR="${ISAACLAB_NEWTON_DIR:-${NEWTON_WALL_BRUSH_WORKSPACE}/IsaacLab-newton}"
NEWTON_DIR="${NEWTON_DIR:-${NEWTON_WALL_BRUSH_WORKSPACE}/newton}"

NEWTON_WALL_BRUSH_TRAINING_ROOT="${NEWTON_WALL_BRUSH_TRAINING_ROOT:-/root/autodl-tmp/IsaacLab}"
NEWTON_WALL_BRUSH_CONDA_ENV="${NEWTON_WALL_BRUSH_CONDA_ENV:-/root/autodl-tmp/envs/isaaclab}"

NEWTON_WALL_BRUSH_EXACT_TRAIN_TASK="${NEWTON_WALL_BRUSH_EXACT_TRAIN_TASK:-Isaac-Motion-Tracking-Wall-Brush-NoWallCollision-DreamControl-ButtonPressAlignedAntiJitter-v0}"
NEWTON_WALL_BRUSH_TASK="${NEWTON_WALL_BRUSH_TASK:-$NEWTON_WALL_BRUSH_EXACT_TRAIN_TASK}"
NEWTON_WALL_BRUSH_PHYSICS_ARG="${NEWTON_WALL_BRUSH_PHYSICS_ARG:-physics=newton_mjwarp}"
NEWTON_WALL_BRUSH_REF_MOTIONS_PATH="${NEWTON_WALL_BRUSH_REF_MOTIONS_PATH:-../TrajGen/sample/Wall_Brush_27/wall_brush_27_prior_references_dreamcontrol_staged250_standprefix_approach_stroke_recover.npz}"
NEWTON_WALL_BRUSH_DEFAULT_OUTPUT="${NEWTON_WALL_BRUSH_DEFAULT_OUTPUT:-/root/autodl-tmp/newton_wall_brush_eval.json}"
